# Copy this file to .env and fill in values. Never commit .env.

# Fly Managed Postgres cluster ID.
# Find it with: fly mpg list
MPG_CLUSTER_ID=

# Credentials for the telive app user (used by add-host-user-prod).
# Find in Fly dashboard > Postgres cluster > Connection details,
# or reset via: fly mpg connect <cluster-id> then ALTER ROLE telive WITH PASSWORD '...';
MPG_USER=telive
MPG_PASS=

# Credentials for the migration superuser (used by db-migrate-prod).
# Find in Fly dashboard > Postgres cluster > Connection details.
MPG_MIGRATE_USER=postgres
MPG_MIGRATE_PASS=

# Schema names — these are fixed values, not secrets.
MPG_SCHEMA=telive
MPG_LB_SCHEMA=public